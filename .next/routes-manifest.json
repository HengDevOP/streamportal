{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/all-donations/[username]",
      "regex": "^/api/all\\-donations/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/api/all\\-donations/(?<nxtPusername>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/overlay/config/[username]",
      "regex": "^/api/overlay/config/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/api/overlay/config/(?<nxtPusername>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/overlay/preview/[username]",
      "regex": "^/api/overlay/preview/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/api/overlay/preview/(?<nxtPusername>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/payment/[username]",
      "regex": "^/api/payment/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/api/payment/(?<nxtPusername>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/top-donations/[username]",
      "regex": "^/api/top\\-donations/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/api/top\\-donations/(?<nxtPusername>[^/]+?)(?:/)?$"
    },
    {
      "page": "/donate/[username]",
      "regex": "^/donate/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/donate/(?<nxtPusername>[^/]+?)(?:/)?$"
    },
    {
      "page": "/overlay/[username]",
      "regex": "^/overlay/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/overlay/(?<nxtPusername>[^/]+?)(?:/)?$"
    },
    {
      "page": "/top/[username]",
      "regex": "^/top/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/top/(?<nxtPusername>[^/]+?)(?:/)?$"
    },
    {
      "page": "/topdonation/[username]",
      "regex": "^/topdonation/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPusername": "nxtPusername"
      },
      "namedRegex": "^/topdonation/(?<nxtPusername>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/dashboard",
      "regex": "^/dashboard(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard(?:/)?$"
    },
    {
      "page": "/dashboard/overlay",
      "regex": "^/dashboard/overlay(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/overlay(?:/)?$"
    },
    {
      "page": "/dashboard/overview",
      "regex": "^/dashboard/overview(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/dashboard/overview(?:/)?$"
    },
    {
      "page": "/pricing",
      "regex": "^/pricing(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/pricing(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}